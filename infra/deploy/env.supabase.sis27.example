# Copy values into infra/supabase/docker/.env (after generating keys — see that folder’s README).
# Use ONE public origin for the browser: the host/port served by sis27-caddy (usually http://<vm-ip> or https://<your-domain>).

SITE_URL=http://127.0.0.1
API_EXTERNAL_URL=http://127.0.0.1
SUPABASE_PUBLIC_URL=http://127.0.0.1

# Nuxt public client (must match browser URL for API calls)
SIS27_PUBLIC_URL=http://127.0.0.1

# POC without SMTP: auto-confirm signups (do not use in production without a mailer).
ENABLE_EMAIL_AUTOCONFIRM=true

# Expose platform plus satellite app schemas through Supabase/PostgREST.
PGRST_DB_SCHEMAS=public,app_contact,app_goals,storage,graphql_public

# Optional: extra redirect URLs for OAuth or alternate frontends (comma-separated).
# ADDITIONAL_REDIRECT_URLS=
