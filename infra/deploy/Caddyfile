# Same-origin browser calls: app HTML from Nuxt, API paths to Kong.
# WebSockets (Realtime) use automatic upgrade on reverse_proxy.

:80 {
	encode gzip

	# All Kong-facing prefixes in one `path` line (OR). Easier to audit and matches `infra/dev/Caddyfile`.
	@api {
		path /auth/* /rest/* /realtime/* /storage/* /functions/* /graphql/* /pg/* /.well-known/* /sso/*
	}
	handle @api {
		reverse_proxy kong:8000
	}

	@contact {
		path /contact /contact/*
	}
	handle @contact {
		reverse_proxy contact:3000
	}

	@goals {
		path /goals /goals/*
	}
	handle @goals {
		reverse_proxy goals:3000
	}

	handle {
		reverse_proxy web:3000
	}
}
