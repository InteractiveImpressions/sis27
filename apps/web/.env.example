# Local dev: point at self-hosted Supabase (Kong) — same origin as the app if you use the VM/Caddy stack on :80.
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NUXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-jwt-from-infra-supabase-docker-env

# Split dev: full URLs to satellite Next apps (defaults in nuxt.config.ts when NODE_ENV=development).
# NUXT_PUBLIC_CONTACT_DEV_ORIGIN=http://localhost:3001
# NUXT_PUBLIC_GOALS_DEV_ORIGIN=http://localhost:3002
