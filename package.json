{
  "name": "sis27",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:down": "./scripts/dev-down.sh",
    "dev:web": "pnpm --filter @sis27/web dev",
    "dev:web-stack": "SIS27_DEV_FRONTEND=web ./scripts/dev.sh",
    "dev:contact": "SIS27_DEV_FRONTEND=contact ./scripts/dev.sh",
    "dev:caddy": "./scripts/dev-caddy.sh",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@sis27/platform": "workspace:*",
    "concurrently": "^9.2.1"
  }
}
