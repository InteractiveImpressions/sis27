{
  "name": "sis27",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:down": "./scripts/dev-down.sh",
    "dev:web": "pnpm --filter @sis27/web dev",
    "dev:contact": "pnpm --filter @sis27/contact dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@sis27/platform": "workspace:*"
    }
  }
}
