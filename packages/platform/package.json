{
  "name": "@sis27/platform",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sis27-stack-down": "./bin/sis27-stack-down.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "node -e \"const fs=require('fs'),{execSync}=require('child_process'); if(fs.existsSync('tsconfig.json')) execSync('tsc -p tsconfig.json',{stdio:'inherit'});\"",
    "prepublishOnly": "pnpm run build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "registry": "https://europe-west3-npm.pkg.dev/sis27-495603/sis27-npm/"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3"
  }
}
